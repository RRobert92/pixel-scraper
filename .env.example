# Pixel Scraper has NO required configuration and needs NO API key.
# Traditional scraping is a plain HTTP fetch + parse. When a page must be
# rendered, the plugin returns screenshot tiles for your own Claude Code
# session to read — extraction runs on your existing Claude subscription, not
# a separate billed API call.
#
# Everything below is optional tuning (defaults shown).

# --- Browser / fetch ---

# Headless-browser navigation timeout (ms).
# PIXEL_SCRAPER_NAV_TIMEOUT_MS=30000

# Plain HTTP fetch timeout for traditional extraction (ms).
# PIXEL_SCRAPER_FETCH_TIMEOUT_MS=15000

# Minimum characters of extracted text before the traditional path is accepted.
# Raise it to render (and tile) more aggressively.
# PIXEL_SCRAPER_MIN_TEXT_LENGTH=200

# Maximum bytes read from a traditional HTTP response (memory-exhaustion guard).
# PIXEL_SCRAPER_MAX_RESPONSE_BYTES=8000000

# Browser + fetch User-Agent.
# PIXEL_SCRAPER_USER_AGENT=

# Run Chromium headless (true) or headed (false, for debugging).
# PIXEL_SCRAPER_HEADLESS=true

# Page width, and the tile height used for non-full-page captures.
# PIXEL_SCRAPER_VIEWPORT_WIDTH=1280
# PIXEL_SCRAPER_VIEWPORT_HEIGHT=1024

# --- Tiling (keeps tall pages legible) ---

# Height of each full-page screenshot tile. Smaller = sharper text but more
# tiles (more context used by your Claude session).
# PIXEL_SCRAPER_TILE_HEIGHT=1400

# Vertical overlap between tiles, so no line of text is cut in half.
# PIXEL_SCRAPER_TILE_OVERLAP=100

# Maximum tiles captured per page (caps context use on very long pages).
# PIXEL_SCRAPER_MAX_TILES=8

# --- Safety / logging ---

# Allow scraping private/loopback hosts (off by default for SSRF safety).
# PIXEL_SCRAPER_ALLOW_PRIVATE_HOSTS=false

# Log verbosity: debug | info | warn | error
# PIXEL_SCRAPER_LOG_LEVEL=info
